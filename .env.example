# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use (comma-separated list for fallback chain, e.g. gemini-2.5-flash,gemini-2.0-flash)
GEMINI_MODELS=gemini-2.5-flash

# Frontend API URL (for client-side requests)
VITE_API_URL=http://localhost:5000

# Backend Server Configuration
PORT=5000
NODE_ENV=development

# CORS Configuration (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

# Guest Account Configuration (for demo/testing)
GUEST_EMAIL=guest@loom.local
GUEST_PASSWORD=guest_demo_password_12345

# Firebase Configuration (Required for Vercel / Production builds if firebase-applet-config.json is absent)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
